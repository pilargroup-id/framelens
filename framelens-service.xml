<!-- FrameLens Service Configuration -->
<service>
  <id>FrameLens</id>
  <name>FrameLens API</name>
  <description>FrameLens Python FastAPI Service</description>
  <executable>C:\laragon\bin\python\python-3.10\python.exe</executable>
  <arguments>-m uvicorn app.main:app --host 0.0.0.0 --port 8005</arguments>
  <workingdirectory>C:\framelens\backend_ai</workingdirectory>
  <logpath>C:\framelens\backend_ai\logs</logpath>
  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>5</keepFiles>
  </log>
  <onfailure action="restart" delay="3 sec"/>
  <onfailure action="restart" delay="10 sec"/>
</service>